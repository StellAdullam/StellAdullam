# apps/webapp/.env.local.example
# Local development defaults for apps/webapp.

# Public API URL used by browser-side API client calls.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-side API URL used by Next.js API routes/proxy handlers.
API_URL=http://localhost:3001

# Shared secret used by the admin operations proxy route.
OPERATIONS_BACKEND_CREDENTIAL=local-dev-credential

# Comma-separated admin wallet allowlist for operations routes.
# Use '*' for local development convenience.
OPERATIONS_ALLOWED_WALLETS=*

# Optional SSE endpoint for real-time lending pool updates.
# Leave empty to use polling fallback in local development.
NEXT_PUBLIC_LENDING_SSE_URL=

# ─── Mock Data Layer ──────────────────────────────────────────────────────────
# Set to "true" to develop frontend without a running backend.
# MSW intercepts all API calls and returns realistic fixture data.
# Flip to "false" (or remove) when your local API server is running.
NEXT_PUBLIC_USE_MOCK=false
