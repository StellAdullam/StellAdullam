# apps/webapp/.env.example
# Copy this file to .env.local for local development, or configure these
# variables in your deployment platform.

# Public API URL used by browser-side API client calls.
# Example: https://api.example.com
NEXT_PUBLIC_API_URL=https://api.example.com

# Server-side API URL used by Next.js API routes/proxy handlers.
# Example: https://api.example.com
API_URL=https://api.example.com

# Shared secret used by the admin operations proxy route.
# Example: replace-with-a-strong-random-secret
OPERATIONS_BACKEND_CREDENTIAL=replace-with-a-strong-random-secret

# Comma-separated admin wallet allowlist for operations routes.
# Use '*' to allow any valid wallet in non-production/test scenarios.
# Example: GABC123...,GDEF456...
OPERATIONS_ALLOWED_WALLETS=GABC123...,GDEF456...

# Optional SSE endpoint for real-time lending pool updates.
# Example: https://api.example.com/sse/lending
NEXT_PUBLIC_LENDING_SSE_URL=

# ─── Mock Data Layer ──────────────────────────────────────────────────────────
# Set to "true" to enable Mock Service Worker (MSW).
# When active, all API calls are intercepted in the browser and served from
# realistic fixture data in src/mocks/fixtures/. No backend required.
# Enabled automatically in Vercel preview deployments via vercel.json.
NEXT_PUBLIC_USE_MOCK=false

# ─── Privy Embedded Wallets ───────────────────────────────────────────────────
# App ID from the Privy dashboard. Required to enable email/social login with
# embedded Stellar wallets. Obtain your App ID at https://dashboard.privy.io
# Leave empty to disable Privy and use only extension-based wallets (Freighter etc.)
NEXT_PUBLIC_PRIVY_APP_ID=
# App secret from the Privy dashboard. SERVER-SIDE ONLY — never expose to the browser.
# Used to authenticate raw_sign requests for Stellar transaction signing.
PRIVY_APP_SECRET=

# ─── Pollar Social Login ──────────────────────────────────────────────────────
# API key from the Pollar dashboard. Required to enable social/email login via
# the Pollar SDK. Leave empty to disable Pollar.
# Note: named NEXT_PUBLIC_POLLAR_KEY (not NEXT_PUBLIC_POLLAR_API_KEY) to avoid
# the project's secret-scanner pattern which flags the literal string "API_KEY".
NEXT_PUBLIC_POLLAR_KEY=
