# apps/stelladullam-land/.env.local.example
# Copy this file to .env.local for local development.
# All variables are optional — the app works with mock data without them.

# Soroban RPC endpoint for Stellar testnet or mainnet.
# Default: https://soroban-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Default viewer address for read-only demo mode when no wallet is connected.
# Leave empty to start fully disconnected.
NEXT_PUBLIC_DEFAULT_VIEWER_ADDRESS=

# Deployed Soroban contract IDs (set after running scripts/deploy.sh).
# See docs/contracts/deployment.md for deployment instructions.
NEXT_PUBLIC_GAME_ENGINE_CONTRACT_ID=
NEXT_PUBLIC_PROPERTY_NFT_CONTRACT_ID=
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ID=
NEXT_PUBLIC_LAND_TOKEN_CONTRACT_ID=

# Treasury wallet address for the game.
NEXT_PUBLIC_TREASURY_ADDRESS=

# Stellar network to connect to.
# Options: testnet, mainnet
# Default: testnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet
